{
  "name": "dl-chan",
  "version": "0.2.2",
  "description": "DL-chan — friendly download manager by Nakano Tabasa",
  "author": "Nakano Tabasa",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/generate-icons.js",
    "fetch:ytdlp": "node scripts/fetch-ytdlp.js",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "dev.nakanotabasa.dlchan",
    "productName": "DL-chan",
    "copyright": "Copyright © Nakano Tabasa",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/ffmpeg-static/**/*"
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
